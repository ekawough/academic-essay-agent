# ============================================================
# ACADEMIC ESSAY AGENT — Environment Variables
# Copy this to .env and fill in your keys
# ============================================================

# --- REQUIRED ---
ANTHROPIC_API_KEY=your_claude_key_here

# --- RESEARCH (free, no key needed for CrossRef/OpenAlex) ---
# Optional: GPT-Researcher uses Tavily for web research
TAVILY_API_KEY=your_tavily_key_here

# --- ORIGINALITY CHECKING (optional, paid) ---
COPYLEAKS_EMAIL=your@email.com
COPYLEAKS_KEY=your_copyleaks_api_key

# --- SUPABASE (optional but recommended for persistence) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- NOTION (optional) ---
NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# --- APP ---
PORT=8000
ENV=development
